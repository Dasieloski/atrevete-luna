# Base de datos PostgreSQL (Vercel Postgres, Neon, Supabase, etc.)
# Formato: postgresql://usuario:contraseña@host:puerto/database?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/atrevete-luna?schema=public"

# Secreto para firmar tokens JWT. Usa un valor aleatorio largo en producción.
# Genera uno con: openssl rand -base64 32
JWT_SECRET="cambia-esto-por-un-secreto-aleatorio-largo-en-produccion"
